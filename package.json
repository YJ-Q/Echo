{
  "name": "margin",
  "version": "0.1.0",
  "description": "Margin - a paper-and-ink companion that keeps the live line visible.",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "prestart": "npm run build:ui",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "dev:ui": "vite --config frontend/vite.config.ts",
    "build:ui": "vite build --config frontend/vite.config.ts",
    "build:icon": "node scripts/build-icon.mjs",
    "lint:ui": "tsc --project frontend/tsconfig.json --noEmit",
    "test": "node --test",
    "prepack:win": "npm run lint:ui && npm run build:ui && npm run build:icon && npm test",
    "pack:win": "npm run prepack:win && electron-builder --win --x64 --dir",
    "dist:win": "npm run prepack:win && electron-builder --win nsis --x64",
    "predesktop": "npm run build:ui",
    "desktop": "electron .",
    "backup": "node scripts/backup-data.js",
    "export:data": "node scripts/backup-data.js --format=json",
    "import:data": "node scripts/import-data.js"
  },
  "keywords": [
    "margin",
    "ai-companion",
    "memory",
    "reflection",
    "paper-interface"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
