PORT=3000
NODE_ENV=development
MARGIN_LOG_LEVEL=info
MARGIN_LLM_PROVIDER=local
MARGIN_DB_PATH=./data/echo.sqlite

# Optional LLM providers.
# MARGIN_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
#
# MARGIN_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# MARGIN_LLM_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2

# Optional SiliconFlow TTS.
# SILICONFLOW_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
# SILICONFLOW_TTS_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex
# SILICONFLOW_TTS_RESPONSE_FORMAT=mp3
# SILICONFLOW_TTS_SPEED=1

# Optional SiliconFlow STT.
# SILICONFLOW_STT_MODEL=FunAudioLLM/SenseVoiceSmall
# SILICONFLOW_STT_LANGUAGE=zh

# Legacy ECHO_* names remain accepted for existing installations.
