# Server
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info

# LLM Provider (choose one)
# Options: siliconflow, openai, anthropic, local (default)
ECHO_LLM_PROVIDER=siliconflow

# SiliconFlow (recommended in China)
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Storage
# Default: <project_root>/data/echo.sqlite
# ECHO_DB_PATH=/custom/path/echo.sqlite
